    {
      "parameters": {
        "language": "pythonNative",
        "pythonCode": "for item in _items:\n    # 1. Extraemos el texto completo que viene del nodo PDF anterior\n    texto_completo = item[\"json\"].get(\"text\", \"\")\n    \n    # 2. Cortamos el texto para quedarnos solo con el inicio (primeros 3000 caracteres)\n    texto_recortado = texto_completo[:3000]\n    \n    # 3. Guardamos este texto limpio en una nueva propiedad para que la reciba Groq\n    item[\"json\"][\"texto_para_ia\"] = texto_recortado\n\n# Devolvemos el elemento modificado a n8n\nreturn _items"
      },
